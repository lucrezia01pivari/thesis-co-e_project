## Combinazione degli oggetti Seurat

```{r merge-treated}
serobj_combined_T <- merge(
  x            = seurat_fltr_T03,
  y            = c(seurat_fltr_T01, seurat_fltr_T02),
  add.cell.ids = c("T01", "T02", "T03"),
  project      = "merged_trt"
)

saveRDS(serobj_combined_T, file = file.path(output_dir, "Trattati_seurat_fltr_combined_preCC.rds"))

serobj_combined_T
head(Cells(serobj_combined_T))
table(serobj_combined_T$orig.ident)
```

