## Distribuzione delle fasi del ciclo cellulare

```{r phase-table}
tabella_counts <- as.data.frame(
  table(
    sample = serobj_combined_T$orig.ident,
    phase  = serobj_combined_T$Phase
  )
)

tabella_counts$Freq <- as.numeric(tabella_counts$Freq)

tabella_counts <- tabella_counts %>%
  group_by(sample) %>%
  mutate(percent = round(100 * Freq / sum(Freq), 2))

print(tabella_counts)
```

```{r phase-barplot}
phase_colors <- c("G1" = "#619CFF", "S" = "#F8766D", "G2M" = "#00BB37")

tabella_counts <- tabella_counts %>%
  mutate(
    percent_prop = percent / 100,
    phase        = factor(phase, levels = c("G1", "S", "G2M"))
  )

png(filename = file.path(img_dir, "istogramma-fasi_T.png"))
print(
  ggplot(tabella_counts, aes(x = sample, y = percent_prop, fill = phase)) +
    geom_col(width = 0.6) +
    scale_fill_manual(values = phase_colors) +
    theme_minimal(base_size = 14)
)
dev.off()
```

