## Setup

```{r setup, message=FALSE, warning=FALSE}
library(Seurat)
library(ggplot2)
library(knitr)
library(dplyr)
```

### Configurazione dei percorsi

Modifica i percorsi qui sotto in base alla tua struttura di directory locale.

```{r paths}
# --- CONFIGURAZIONE PERCORSI ---
# Modifica questi percorsi prima di eseguire il notebook

base_input_dir <- "data"           # cartella radice dei dati di input
output_dir     <- "output/rds"     # cartella per i file .rds in output
img_dir        <- "immagini/Trattati"  # cartella per le immagini

file_path1 <- file.path(base_input_dir, "RT01", "count", "sample_filtered_feature_bc_matrix")
file_path2 <- file.path(base_input_dir, "RT02", "count", "sample_filtered_feature_bc_matrix")
file_path3 <- file.path(base_input_dir, "RT03", "count", "sample_filtered_feature_bc_matrix")

# Crea le cartelle di output se non esistono
dir.create(output_dir, recursive = TRUE, showWarnings = FALSE)
dir.create(img_dir,    recursive = TRUE, showWarnings = FALSE)
```

------------------------------------------------------------------------

## Note sui parametri QC

-   **nFeature_RNA**: numero di geni distinti rilevati per cellula durante il sequenziamento.
-   **nCount_RNA**: numero totale di trascritti RNA sequenziati per cellula.
-   **percent.mt**: percentuale di geni mitocondriali rilevata per cellula (valori alti indicano possibile danno cellulare).

------------------------------------------------------------------------

## Campione T01

```{r load-T01}
expression_matrix_T1 <- Read10X(data.dir = file_path1)
expression_matrix_T1[1:10, 1:3]
```

### Creazione oggetto Seurat

```{r seurat-T01}
seurat_T01 <- CreateSeuratObject(
  counts       = expression_matrix_T1,
  min.cells    = 3,
  min.features = 200,
  project      = "T01"
)

seurat_T01
dim(seurat_T01)
head(colnames(seurat_T01))
head(rownames(seurat_T01))
```

### QC pre-filtraggio

```{r qc-pref-T01}
seurat_T01[["percent.mt"]] <- PercentageFeatureSet(seurat_T01, pattern = "^MT-")

png(filename = file.path(img_dir, "T01_QC_pref.png"))
VlnPlot(seurat_T01, features = c("nFeature_RNA", "nCount_RNA", "percent.mt"), ncol = 3, cols = "#9A0135")
dev.off()

FeatureScatter(seurat_T01, feature1 = "nCount_RNA", feature2 = "percent.mt") + NoLegend() +
  FeatureScatter(seurat_T01, feature1 = "nCount_RNA", feature2 = "nFeature_RNA") + NoLegend()
```

### Statistiche descrittive pre-filtraggio — T01

```{r stats-pref-T01}
summary_T01 <- data.frame(
  Metric = c("nFeature_RNA", "nCount_RNA", "percent.mt"),
  Mean   = c(mean(seurat_T01$nFeature_RNA), mean(seurat_T01$nCount_RNA), mean(seurat_T01$percent.mt)),
  SD     = c(sd(seurat_T01$nFeature_RNA),   sd(seurat_T01$nCount_RNA),   sd(seurat_T01$percent.mt))
)
print(summary_T01)
```

### Filtraggio delle cellule di bassa qualità

```{r filter-T01}
seurat_fltr_T01 <- subset(
  seurat_T01,
  subset = nFeature_RNA >  150 &
           nFeature_RNA < 1500 &
           percent.mt   <   25
)

png(filename = file.path(img_dir, "T01_QC_postf.png"))
VlnPlot(seurat_fltr_T01, features = c("nFeature_RNA", "nCount_RNA", "percent.mt"), ncol = 3, cols = "#9A0135")
dev.off()

saveRDS(seurat_fltr_T01, file = file.path(output_dir, "Trattati_seurat_fltr_T01.rds"))
```

### Statistiche descrittive post-filtraggio — T01

```{r stats-postf-T01}
summary_fltr_T01 <- data.frame(
  Metric = c("nFeature_RNA", "nCount_RNA", "percent.mt"),
  Mean   = c(mean(seurat_fltr_T01$nFeature_RNA), mean(seurat_fltr_T01$nCount_RNA), mean(seurat_fltr_T01$percent.mt)),
  SD     = c(sd(seurat_fltr_T01$nFeature_RNA),   sd(seurat_fltr_T01$nCount_RNA),   sd(seurat_fltr_T01$percent.mt))
